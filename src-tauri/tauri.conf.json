{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gestione Preventivi",
  "version": "1.0.5",
  "identifier": "it.benzxi.preventivi",
  "build": {
    "beforeBuildCommand": "npm run desktop:prepare",
    "frontendDist": "frontend"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Gestione Preventivi",
    "resources": [
      "resources/server",
      "resources/runtime/node.exe",
      "resources/template-data",
      "resources/browser",
      "resources/vc_redist.x64.exe"
    ],
    "icon": ["icons/icon.ico"],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      },
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["Italian"],
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  }
}
